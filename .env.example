# ===== XTM Acolad Portal (เป้าหมายหลักของ 002) =====
# หน้า login ของ XTM (host ยืนยันจาก recon D1: xtm.acolad.com/project-manager-gui)
XTM_ACOLAD_PORTAL_URL=https://xtm.acolad.com/project-manager-gui/login.jsp?client=YOUR-COMPANY
# มุมมอง Active (my-inbox) ที่เฝ้า — ยืนยันจาก recon D1
XTM_ACOLAD_OFFERS_URL=https://xtm.acolad.com/project-manager-gui/my-inbox-pages.action
# มุมมอง Closed — targeted check ตอนงาน accepted หาย (Closed vs Removed, FR-014); ยืนยัน recon D8
XTM_ACOLAD_CLOSED_URL=https://xtm.acolad.com/project-manager-gui/my-inbox-closed-tasks-page.action
# ข้อมูล login บัญชีแชร์ — ทั้งสามค่าเป็น secret (อยู่ใน redaction list); ใส่ค่าจริงใน .env เท่านั้น
XTM_ACOLAD_Company=YOUR-COMPANY
XTM_ACOLAD_Username=your-username
XTM_ACOLAD_Password=your-xtm-password

# ===== Google Chat Webhooks =====
# ช่องแจ้งเตือนระบบ (งานใหม่ + ผลกดรับ + ปัญหาระบบ + heartbeat alert) — จำเป็น
GOOGLE_CHAT_WEBHOOK_SYSTEM=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX
# Team space webhook — daily report + accepted-job announcements (required, secret)
GOOGLE_CHAT_WEBHOOK_TEAM=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX
# ช่องรายงานประจำวัน — [deprecated: ใช้ GOOGLE_CHAT_WEBHOOK_TEAM แทน] สงวนไว้สำหรับ backward compat ปล่อยว่างได้
GOOGLE_CHAT_WEBHOOK_DAILY_REPORT=

# ===== Google Sheets (บันทึกทุกงาน — 002 จำเป็น) =====
# id จาก URL ชีต (https://docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_ID=
# service account key (gitignored) — ค่า default = google-credentials.json
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=google-credentials.json
# ชื่อ tab เป้าหมาย (map จาก gid ตอน recon D7)
SHEETS_TAB_NAME=Tasks

# ===== Accept control (กดรับงานอัตโนมัติ) =====
# kill-switch (FR-012): 0 = ตรวจจับ+log+แจ้ง แต่ "ไม่กดรับ"; ตั้งต้น OFF เพื่อความปลอดภัย
# เปิด 1 หลัง recon ยืนยัน accept flow จริงแล้วเท่านั้น
ACCEPT_ENABLED=0
# evidence-only recon (FR-011/D6): 1 = เมื่อเจองานมาเลย์ (ตอน ACCEPT_ENABLED=0) ให้
# เปิดเมนู accept เก็บ DOM จริง (hover only ไม่กดรับ) เพื่อยืนยันสัญญาณ "Accept task" vs
# "Finish task" แล้วคำนวณ acceptAvailable; ส่ง Chat แจ้งครั้งเดียว. ปลอดภัยเปิดทิ้งไว้
ACCEPT_RECON=0
# รายการ target language ที่ eligible (csv) — config-driven (R8)
ACCEPT_LANGUAGES=Malay (Malaysia)
# เพดานคำต่องานที่กดรับอัตโนมัติ (FR-025); 0 = ไม่จำกัด
ACCEPT_MAX_WORDS=0
# เพดานจำนวนกดรับต่อรอบ (FR-025); 0 = ไม่จำกัด
ACCEPT_MAX_PER_CYCLE=0

# --- Auto-yield: back off when a human/another session uses the shared XTM account ---
# The bot and the team share ONE XTM login that allows only one session at a time.
# When the bot detects it was logged off by another user it yields instead of
# re-logging in (which would kick the human). Set to 0 to disable (e.g. once the
# bot has its OWN XTM account).
XTM_YIELD_ENABLED=1
# Cooldown between yield re-probes AND the "recently authenticated" threshold.
# MUST be >= 3 x POLL_INTERVAL_MS or the bot refuses to start.
XTM_YIELD_WINDOW_MS=600000
# Hard cap: if the bot stays yielded this long it raises a critical alert and pages
# on-call (a teammate may have left a session open, or XTM may be stuck).
XTM_YIELD_MAX_MINUTES=60

# ===== Heartbeat (Healthchecks.io dead-man switch) =====
# จำเป็น — สร้าง check (period 5 นาที, grace ≤ 10 นาที ตาม Constitution IV) แล้ววาง ping URL
# ⚠️ ค่านี้เป็น secret: ใครได้ URL ไปสามารถ ping ปลอมทำให้ระบบเฝ้าระวังไม่แจ้งเตือน
HEALTHCHECKS_PING_URL=

# ===== Tuning (optional — ค่า default ตาม contracts/config.md) =====
# รอบตรวจปกติ ms (zod บังคับ 20000-25000); 002 = 20000 (ปลายเร็วสุด ชนะหน้าต่าง < 1 นาที, R7)
#POLL_INTERVAL_MS=20000
# พอร์ต lock กันรันซ้อน (bind 127.0.0.1:<พอร์ต>) — ตัวที่สองจะ refuse.
# ⚠️ ถ้าแก้ค่านี้ ต้องแก้ $Port ใน scripts/deploy.ps1 ให้ตรงกันด้วย (deploy ไม่อ่าน .env)
#SINGLE_INSTANCE_PORT=47811
# จำนวน login ล้มเหลวก่อน lockout + alert
#LOGIN_MAX_RETRY=3
# ระยะหยุดพยายาม login (นาที)
#LOGIN_LOCKOUT_MINUTES=15
# รอบ recycle browser กัน memory leak (ชั่วโมง)
#BROWSER_RECYCLE_HOURS=6
# ที่เก็บ JSON logs (rotate 14 วัน)
#LOG_DIR=logs
# ที่เก็บ SQLite + storageState + evidence
#STATE_DIR=state
# เขตเวลาแสดงผล
#TZ_DISPLAY=Asia/Bangkok
# จำนวน retry สูงสุดต่อรายการแจ้งเตือนก่อนเปลี่ยนเป็น dead (FR-018)
#OUTBOX_RETRY_CAP=10
# อายุสูงสุด (ชม.) ของรายการค้างส่งก่อนเปลี่ยนเป็น dead (FR-018)
#OUTBOX_DEAD_AFTER_HOURS=6
# ตั้งเป็น 1 เพื่อเปิด live smoke test / recon กับ portal จริง (ห้ามใช้ใน CI)
#LIVE_PORTAL=

# --- Auto-accept scheduling (working-hours feasibility + daily word cap) ---
ACCEPT_SCHEDULE_ENABLED=1            # 0/false/off/no disables (then today's behavior)
ACCEPT_HOURS_START=09:00             # working-window start (Bangkok)
ACCEPT_HOURS_END=18:00               # working-window end (exclusive)
ACCEPT_WORKDAYS=1-5                  # ISO weekdays Mon=1..Sun=7 (ranges/lists)
ACCEPT_MAX_WORDS_PER_DAY=1000        # daily word budget; the primary knob; 0 = unlimited
ACCEPT_THROUGHPUT_WORDS_PER_HOUR=    # empty = derived (capacity ÷ working-hours/day ≈ 111); set to pin
ACCEPT_EFFORT_METRIC=wwc             # wwc = cap/throughput วัดด้วย File WWC (Weighted Word Count หลังหัก TM, ค่า default); words = พฤติกรรมเดิม byte-for-byte
ACCEPT_MAX_WWC_PER_DAY=1000          # daily WWC budget (โหมด wwc); WWC ≤ words → 1000 WWC/วัน คือ งานจริงมากกว่า 1000 words; ปรับให้ตรง capacity ทีม
ACCEPT_THROUGHPUT_WWC_PER_HOUR=      # empty = derived (ACCEPT_MAX_WWC_PER_DAY ÷ ชม.ทำงาน/วัน); โหมด wwc เท่านั้น (ACCEPT_THROUGHPUT_WORDS_PER_HOUR ใช้เฉพาะโหมด words)
