# ===== Acolad Partner Portal =====
ACOLAD_PORTAL_URL=https://partner.acolad.com/login
# หน้ารายการงานที่เฝ้า (ค่า default = pending offers, card view)
ACOLAD_OFFERS_URL=https://partner.acolad.com/project/offer/list/pending?view=card&grouped=false
ACOLAD_EMAIL=your-email@example.com
ACOLAD_PASSWORD=your-password

# ===== Google Chat Webhooks =====
# ช่องแจ้งเตือนระบบ (งานใหม่ + ปัญหาระบบ + heartbeat alert) — จำเป็น
GOOGLE_CHAT_WEBHOOK_SYSTEM=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX

# ช่องรายงานประจำวัน — สงวนไว้สำหรับฟีเจอร์ภายหลัง ปล่อยว่างได้
GOOGLE_CHAT_WEBHOOK_DAILY_REPORT=

# ===== Google Sheets =====
# ใช้ตอนฟีเจอร์ "กดรับงาน" (บันทึกรายละเอียด task ที่กดรับ) — ฟีเจอร์ตรวจจับไม่ใช้ ปล่อยว่างได้
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# ===== Heartbeat (Healthchecks.io dead-man switch) =====
# จำเป็น — สร้าง check (period 5 นาที, grace 5 นาที) แล้ววาง ping URL
# ⚠️ ค่านี้เป็น secret: ใครได้ URL ไปสามารถ ping ปลอมทำให้ระบบเฝ้าระวังไม่แจ้งเตือน
HEALTHCHECKS_PING_URL=

# ===== Tuning (optional — ค่า default ตาม contracts/config.md) =====
# รอบตรวจปกติ ms (zod บังคับ 20000-25000 เพื่อให้ interval+jitter อยู่ใน 20-30s)
#POLL_INTERVAL_MS=25000
# จำนวน login ล้มเหลวก่อน lockout + alert
#LOGIN_MAX_RETRY=3
# ระยะหยุดพยายาม login (นาที)
#LOGIN_LOCKOUT_MINUTES=15
# รอบ recycle browser กัน memory leak (ชั่วโมง)
#BROWSER_RECYCLE_HOURS=6
# ที่เก็บ JSON logs (rotate 14 วัน)
#LOG_DIR=logs
# ที่เก็บ SQLite + storageState + evidence
#STATE_DIR=state
# เขตเวลาแสดงผล
#TZ_DISPLAY=Asia/Bangkok
# จำนวน retry สูงสุดต่อรายการแจ้งเตือนก่อนเปลี่ยนเป็น dead (FR-018)
#OUTBOX_RETRY_CAP=10
# อายุสูงสุด (ชม.) ของรายการค้างส่งก่อนเปลี่ยนเป็น dead (FR-018)
#OUTBOX_DEAD_AFTER_HOURS=6
# ตั้งเป็น 1 เพื่อเปิด live smoke test กับ portal จริง (ห้ามใช้ใน CI)
#LIVE_PORTAL=
