{
  "name": "acolad-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Acolad Partner Portal job detection bot — 24/7 monitor + Google Chat notifications",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "poll:once": "npm run build && node dist/runtime/once.js",
    "start": "npm run build && node dist/runtime/main.js",
    "outbox:requeue": "npm run build && node dist/runtime/requeue.js",
    "report:latency": "npm run build && node dist/runtime/latencyReport.js",
    "report:catch-rate": "npm run build && node dist/runtime/catchRateReport.js",
    "xtm:recon": "tsc scripts/xtm-recon.ts --outDir dist-recon --module nodenext --moduleResolution nodenext --target ES2022 --skipLibCheck && node dist-recon/xtm-recon.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "googleapis": "^173.0.0",
    "pino": "^9.6.0",
    "pino-roll": "^2.2.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
